# ============================================================
# FITY — Variaveis de ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no git (ja esta no .gitignore)
# ============================================================

# ---------- SUPABASE (frontend publico) ----------
# Pega em https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------- SUPABASE (backend apenas - NUNCA expor no browser) ----------
# ⚠️ Essa key BYPASSA RLS. NUNCA colocar em NEXT_PUBLIC_* nem mandar pro front.
# Na Vercel: adicione como variavel normal (sem prefixo NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- Z-API (WhatsApp - backend apenas) ----------
# Pega em https://app.z-api.io após criar a instancia
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ---------- WHATSAPP (frontend publico) ----------
# Numero do bot (com DDI+DDD, sem + ou espacos). Exemplo: 5511988887777
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
# Mensagem pre-preenchida quando alguem clica no botao do Zap
NEXT_PUBLIC_WHATSAPP_MESSAGE=Oi! Quero testar o Fity por 7 dias gratis.

# ---------- WEBHOOK SECURITY (opcional) ----------
# Se voce setar essa variavel, o webhook do Supabase vai exigir esse valor
# no header "x-webhook-secret". Se deixar vazio, sem validacao (dev only).
# Recomendado em producao: gerar uma string random tipo "wb_2kf93hdksl29f"
WEBHOOK_SECRET=

# ---------- ANTHROPIC (Claude AI) - opcional, nao usamos no MVP ----------
# Pega em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------- GOOGLE GEMINI (IA gratuita) - Cérebro do Fity ----------
# Pega em https://aistudio.google.com/app/apikey (gratis)
GEMINI_API_KEY=

# ---------- CRON SECRET (autentica o Vercel Cron) ----------
# Gera uma string random em https://generate-secret.vercel.app/32
# Vercel Cron envia automaticamente como header: Authorization: Bearer <CRON_SECRET>
# Tambem pode ser passado via query: ?secret=<CRON_SECRET> (pra teste manual)
CRON_SECRET=

# ---------- MERCADO PAGO (Checkout / Assinaturas) ----------
# Credenciais em https://www.mercadopago.com.br/developers/panel/credentials
# Public key: comeca com APP_USR- e termina com -public
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxxxx-xxxxxx-xxxxxx-public
# Access token: SERVER-SIDE ONLY. NUNCA com prefixo NEXT_PUBLIC_
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxx-xxxxxx-xxxxxxxx
# URL base do app (usado nos back_urls do checkout)
NEXT_PUBLIC_BASE_URL=https://fity.com.br