{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/keepalive",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/process-trials",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/check-trial-ended",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/check-expirations",
      "schedule": "0 14 * * *"
    }
  ]
}